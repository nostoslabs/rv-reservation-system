{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema/capability.json",
  "identifier": "default",
  "description": "Default capabilities for the RV reservation app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "fs:default",
    "fs:read-files",
    "fs:write-files",
    {
      "identifier": "fs:scope",
      "allow": ["$HOME/**"]
    },
    "window-state:default"
  ]
}
